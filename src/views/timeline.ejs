<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: <%= mainColor %>;
            --bg: #f8fafc;
            --paper: #ffffff;
            --ink: #0f172a;
            --muted: #475569;
            --line: #e2e8f0;
        }

        body.dark-theme {
            --bg: #020617;
            --paper: #0f172a;
            --ink: #f8fafc;
            --muted: #94a3b8;
            --line: #334155;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Manrope', sans-serif;
            color: var(--ink);
            background: var(--bg);
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            font-size: 12px;
            line-height: 1.55;
        }

        .page {
            width: 210mm;
            min-height: 297mm;
            background: var(--paper);
            padding: 24px 26px;
        }

        .hero {
            border: 1px solid var(--line);
            border-left: 8px solid var(--primary);
            border-radius: 14px;
            padding: 18px;
            margin-bottom: 16px;
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 14px;
            align-items: center;
        }

        .hero h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 30px;
            line-height: 1.05;
            margin-bottom: 4px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .hero .title {
            color: color-mix(in srgb, var(--primary) 78%, #111827);
            font-weight: 700;
            margin-bottom: 6px;
        }

        .hero .goal {
            color: var(--muted);
            margin-bottom: 8px;
        }

        .contacts {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            color: var(--muted);
            font-size: 11px;
        }

        .contacts span {
            border: 1px solid var(--line);
            border-radius: 999px;
            padding: 2px 8px;
            background: color-mix(in srgb, var(--paper) 75%, var(--bg));
        }

        .contacts a {
            color: inherit;
            text-decoration: none;
        }

        .photo {
            width: 95px;
            height: 95px;
            border-radius: 18px;
            object-fit: cover;
            border: 3px solid color-mix(in srgb, var(--primary) 65%, white);
        }

        .columns {
            display: grid;
            grid-template-columns: 66% 34%;
            gap: 16px;
        }

        .section {
            margin-bottom: 14px;
        }

        h2 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1.1px;
            margin-bottom: 8px;
            color: var(--ink);
        }

        .timeline {
            border-left: 2px solid color-mix(in srgb, var(--primary) 45%, var(--line));
            padding-left: 13px;
        }

        .item {
            position: relative;
            margin-bottom: 13px;
        }

        .item:last-child {
            margin-bottom: 0;
        }

        .item::before {
            content: "";
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--primary);
            position: absolute;
            left: -18px;
            top: 5px;
        }

        .item-head {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            gap: 8px;
            margin-bottom: 3px;
        }

        .role {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 13px;
            font-weight: 600;
        }

        .date {
            font-size: 11px;
            color: var(--muted);
            white-space: nowrap;
        }

        .org {
            color: color-mix(in srgb, var(--primary) 75%, #111827);
            font-weight: 600;
            margin-bottom: 3px;
        }

        .desc {
            color: var(--muted);
            margin-bottom: 4px;
        }

        ul {
            list-style: none;
        }

        li {
            color: var(--muted);
            position: relative;
            padding-left: 10px;
            margin-bottom: 3px;
        }

        li::before {
            content: "-";
            position: absolute;
            left: 0;
            top: 0;
            color: var(--primary);
            font-weight: 700;
        }

        .panel {
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 10px;
            margin-bottom: 10px;
        }

        .pill-wrap {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .pill {
            border: 1px solid var(--line);
            border-radius: 999px;
            padding: 2px 8px;
            font-size: 10px;
            background: color-mix(in srgb, var(--paper) 75%, var(--bg));
        }

        .language-row {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            margin-bottom: 5px;
        }
    </style>
</head>

<body class="<%= theme === 'dark' ? 'dark-theme' : '' %>">
    <div class="page">
        <header class="hero">
            <div>
                <h1><%= header.name %></h1>
                <div class="title"><%= header.title %></div>
                <% if (header.jobSearchGoal) { %>
                <p class="goal"><%= header.jobSearchGoal %></p>
                <% } %>
                <div class="contacts">
                    <% if (header.age) { %><span>Age: <%= header.age %></span><% } %>
                    <% if (header.contact.location) { %><span><%= header.contact.location %></span><% } %>
                    <% if (header.contact.phone) { %><span><%= header.contact.phone %></span><% } %>
                    <% if (header.contact.email) { %><span><a href="mailto:<%= header.contact.email %>"><%= header.contact.email %></a></span><% } %>
                    <% if (header.contact.linkedinLabel) { %><span><a href="<%= header.contact.linkedinUrl %>" target="_blank" rel="noopener noreferrer"><%= header.contact.linkedinLabel %></a></span><% } %>
                    <% if (header.contact.githubLabel) { %><span><a href="<%= header.contact.githubUrl %>" target="_blank" rel="noopener noreferrer"><%= header.contact.githubLabel %></a></span><% } %>
                </div>
            </div>
            <% if (header.pictureBase64) { %>
            <img src="<%= header.pictureBase64 %>" class="photo" alt="Profile" />
            <% } %>
        </header>

        <div class="columns">
            <main>
                <% if (experiences && experiences.length > 0) { %>
                <section class="section">
                    <h2><%= labels.experiences %></h2>
                    <div class="timeline">
                        <% experiences.forEach(function(exp) { %>
                        <article class="item">
                            <div class="item-head">
                                <div class="role"><%= exp.role %></div>
                                <div class="date"><%= exp.date %></div>
                            </div>
                            <div class="org"><%= exp.company %></div>
                            <% if (exp.description) { %><p class="desc"><%= exp.description %></p><% } %>
                            <% if (exp.tasks && exp.tasks.length > 0) { %>
                            <ul>
                                <% exp.tasks.forEach(function(task) { %><li><%= task %></li><% }); %>
                            </ul>
                            <% } %>
                        </article>
                        <% }); %>
                    </div>
                </section>
                <% } %>

                <% if (projects && projects.length > 0) { %>
                <section class="section">
                    <h2><%= labels.projects %></h2>
                    <div class="timeline">
                        <% projects.forEach(function(p) { %>
                        <article class="item">
                            <div class="item-head">
                                <div class="role"><%= p.title %></div>
                                <div class="date"><%= p.stack %></div>
                            </div>
                            <p class="desc"><%= p.description %></p>
                        </article>
                        <% }); %>
                    </div>
                </section>
                <% } %>

                <% if (education && education.length > 0) { %>
                <section class="section">
                    <h2><%= labels.education %></h2>
                    <div class="timeline">
                        <% education.forEach(function(edu) { %>
                        <article class="item">
                            <div class="item-head">
                                <div class="role"><%= edu.degree %></div>
                                <div class="date"><%= edu.date %></div>
                            </div>
                            <div class="org"><%= edu.school %></div>
                            <% if (edu.details) { %><p class="desc"><%= edu.details %></p><% } %>
                        </article>
                        <% }); %>
                    </div>
                </section>
                <% } %>
            </main>

            <aside>
                <% if (skills && skills.length > 0) { %>
                <section class="panel">
                    <h2><%= labels.hardSkills %></h2>
                    <div class="pill-wrap">
                        <% skills.forEach(function(skill) { %><span class="pill"><%= skill %></span><% }); %>
                    </div>
                </section>
                <% } %>

                <% if (softSkills && softSkills.length > 0) { %>
                <section class="panel">
                    <h2><%= labels.softSkills %></h2>
                    <ul>
                        <% softSkills.forEach(function(skill) { %><li><%= skill %></li><% }); %>
                    </ul>
                </section>
                <% } %>

                <% if (languages && languages.length > 0) { %>
                <section class="panel">
                    <h2><%= labels.languages %></h2>
                    <% languages.forEach(function(l) { %>
                    <div class="language-row"><span><%= l.name %></span><strong><%= l.level %></strong></div>
                    <% }); %>
                </section>
                <% } %>
            </aside>
        </div>
    </div>
</body>

</html>
