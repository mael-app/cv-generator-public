<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Sans:wght@500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: <%= mainColor %>;
            --ink: #0f172a;
            --muted: #475569;
            --panel-bg: #f8fafc;
            --panel-ink: #1e293b;
            --line: #e2e8f0;
            --chip-bg: #e2e8f0;
            --page-bg: #ffffff;
        }

        body.dark-theme {
            --ink: #f8fafc;
            --muted: #94a3b8;
            --panel-bg: #0f172a;
            --panel-ink: #e2e8f0;
            --line: #334155;
            --chip-bg: #1e293b;
            --page-bg: #020617;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--ink);
            background: var(--page-bg);
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            font-size: 12px;
            line-height: 1.5;
        }

        .page {
            width: 210mm;
            min-height: 297mm;
            display: grid;
            grid-template-columns: 33% 67%;
            background: var(--page-bg);
        }

        .sidebar {
            background: linear-gradient(180deg, color-mix(in srgb, var(--primary) 24%, var(--panel-bg)), var(--panel-bg));
            border-right: 1px solid var(--line);
            padding: 28px 22px;
            color: var(--panel-ink);
        }

        .main {
            padding: 30px 28px;
        }

        .photo {
            width: 106px;
            height: 106px;
            border-radius: 16px;
            object-fit: cover;
            border: 3px solid color-mix(in srgb, var(--primary) 60%, white);
            margin-bottom: 14px;
        }

        h1 {
            font-family: 'IBM Plex Sans', sans-serif;
            font-size: 28px;
            line-height: 1.1;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-bottom: 4px;
        }

        .title {
            font-family: 'IBM Plex Sans', sans-serif;
            font-size: 14px;
            font-weight: 600;
            color: color-mix(in srgb, var(--primary) 70%, #111827);
            margin-bottom: 10px;
        }

        .goal {
            color: var(--muted);
            margin-bottom: 18px;
        }

        .stack {
            display: grid;
            gap: 6px;
            margin-bottom: 18px;
        }

        .contact-item {
            font-size: 11px;
            color: var(--panel-ink);
            word-break: break-word;
        }

        .contact-item a {
            color: inherit;
            text-decoration: none;
            border-bottom: 1px dotted color-mix(in srgb, var(--panel-ink) 50%, transparent);
        }

        .section {
            margin-bottom: 18px;
        }

        h2 {
            font-family: 'IBM Plex Sans', sans-serif;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
            padding-bottom: 4px;
            border-bottom: 1px solid var(--line);
        }

        .chip-wrap {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .chip {
            background: var(--chip-bg);
            border: 1px solid var(--line);
            border-radius: 999px;
            font-size: 10px;
            padding: 3px 9px;
            color: var(--panel-ink);
        }

        .item {
            margin-bottom: 14px;
        }

        .item:last-child {
            margin-bottom: 0;
        }

        .meta {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            gap: 8px;
            margin-bottom: 3px;
        }

        .role {
            font-family: 'IBM Plex Sans', sans-serif;
            font-weight: 700;
            font-size: 13px;
        }

        .date {
            color: var(--muted);
            font-size: 11px;
            white-space: nowrap;
        }

        .org {
            color: color-mix(in srgb, var(--primary) 75%, #111827);
            font-weight: 600;
            margin-bottom: 4px;
        }

        .desc {
            color: var(--muted);
            margin-bottom: 5px;
        }

        ul {
            list-style: none;
        }

        li {
            margin-bottom: 3px;
            color: var(--muted);
            position: relative;
            padding-left: 10px;
        }

        li::before {
            content: "";
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: var(--primary);
            position: absolute;
            left: 0;
            top: 7px;
        }

        .lang-row {
            display: flex;
            justify-content: space-between;
            gap: 8px;
            font-size: 11px;
            margin-bottom: 5px;
        }
    </style>
</head>

<body class="<%= theme === 'dark' ? 'dark-theme' : '' %>">
    <div class="page">
        <aside class="sidebar">
            <% if (header.pictureBase64) { %>
            <img src="<%= header.pictureBase64 %>" class="photo" alt="Profile" />
            <% } %>

            <h1><%= header.name %></h1>
            <div class="title"><%= header.title %></div>
            <% if (header.jobSearchGoal) { %>
            <p class="goal"><%= header.jobSearchGoal %></p>
            <% } %>

            <div class="stack">
                <% if (header.age) { %><div class="contact-item"><strong>Age:</strong> <%= header.age %></div><% } %>
                <% if (header.contact.location) { %><div class="contact-item"><%= header.contact.location %></div><% } %>
                <% if (header.contact.phone) { %><div class="contact-item"><%= header.contact.phone %></div><% } %>
                <% if (header.contact.email) { %><div class="contact-item"><a href="mailto:<%= header.contact.email %>"><%= header.contact.email %></a></div><% } %>
                <% if (header.contact.linkedinLabel) { %><div class="contact-item"><a href="<%= header.contact.linkedinUrl %>" target="_blank" rel="noopener noreferrer"><%= header.contact.linkedinLabel %></a></div><% } %>
                <% if (header.contact.githubLabel) { %><div class="contact-item"><a href="<%= header.contact.githubUrl %>" target="_blank" rel="noopener noreferrer"><%= header.contact.githubLabel %></a></div><% } %>
            </div>

            <% if (skills && skills.length > 0) { %>
            <section class="section">
                <h2><%= labels.hardSkills %></h2>
                <div class="chip-wrap">
                    <% skills.forEach(function(skill) { %>
                    <span class="chip"><%= skill %></span>
                    <% }); %>
                </div>
            </section>
            <% } %>

            <% if (languages && languages.length > 0) { %>
            <section class="section">
                <h2><%= labels.languages %></h2>
                <% languages.forEach(function(l) { %>
                <div class="lang-row"><span><%= l.name %></span><strong><%= l.level %></strong></div>
                <% }); %>
            </section>
            <% } %>

            <% if (softSkills && softSkills.length > 0) { %>
            <section class="section">
                <h2><%= labels.softSkills %></h2>
                <ul>
                    <% softSkills.forEach(function(s) { %>
                    <li><%= s %></li>
                    <% }); %>
                </ul>
            </section>
            <% } %>
        </aside>

        <main class="main">
            <% if (experiences && experiences.length > 0) { %>
            <section class="section">
                <h2><%= labels.experiences %></h2>
                <% experiences.forEach(function(exp) { %>
                <article class="item">
                    <div class="meta">
                        <div class="role"><%= exp.role %></div>
                        <div class="date"><%= exp.date %></div>
                    </div>
                    <div class="org"><%= exp.company %></div>
                    <% if (exp.description) { %><p class="desc"><%= exp.description %></p><% } %>
                    <% if (exp.tasks && exp.tasks.length > 0) { %>
                    <ul>
                        <% exp.tasks.forEach(function(task) { %>
                        <li><%= task %></li>
                        <% }); %>
                    </ul>
                    <% } %>
                </article>
                <% }); %>
            </section>
            <% } %>

            <% if (projects && projects.length > 0) { %>
            <section class="section">
                <h2><%= labels.projects %></h2>
                <% projects.forEach(function(p) { %>
                <article class="item">
                    <div class="meta">
                        <div class="role"><%= p.title %></div>
                        <div class="date"><%= p.stack %></div>
                    </div>
                    <p class="desc"><%= p.description %></p>
                </article>
                <% }); %>
            </section>
            <% } %>

            <% if (education && education.length > 0) { %>
            <section class="section">
                <h2><%= labels.education %></h2>
                <% education.forEach(function(edu) { %>
                <article class="item">
                    <div class="meta">
                        <div class="role"><%= edu.degree %></div>
                        <div class="date"><%= edu.date %></div>
                    </div>
                    <div class="org"><%= edu.school %></div>
                    <% if (edu.details) { %><p class="desc"><%= edu.details %></p><% } %>
                </article>
                <% }); %>
            </section>
            <% } %>
        </main>
    </div>
</body>

</html>
