<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --primary: <%=mainColor %>;
            --text-dark: #1e293b;
            --text-light: #64748b;
            --bg-shape: <%=mainColor %>10;
            --bg-gray: #f8fafc;
            --bg-body: white;
            --item-bg: white;
        }

        body.dark-theme {
            --text-dark: #f1f5f9;
            --text-light: #94a3b8;
            --bg-gray: #1e293b;
            --bg-body: #0f172a;
            --bg-shape: <%=mainColor %>30;
            --item-bg: #1e293b;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--text-dark);
            background: var(--bg-body);
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            font-size: 14px;
            line-height: 1.6;
        }

        .page {
            width: 210mm;
            height: 297mm;
            padding: 50px 60px;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            background: var(--bg-body);
        }

        a {
            color: inherit;
            text-decoration: none;
            border-bottom: 1px dotted var(--text-light);
            transition: color 0.2s;
        }

        a:hover {
            color: var(--primary);
            border-bottom-style: solid;
        }

        .shape-top-right {
            position: absolute;
            top: -80px;
            right: -80px;
            width: 300px;
            height: 300px;
            background: var(--bg-shape);
            border-radius: 50%;
            z-index: 0;
        }

        .shape-bottom-left {
            position: absolute;
            bottom: -40px;
            left: -40px;
            width: 200px;
            height: 200px;
            border: 30px solid var(--bg-shape);
            border-radius: 30px;
            transform: rotate(15deg);
            z-index: 0;
        }

        header {
            position: relative;
            z-index: 1;
            margin-bottom: 45px;
            display: flex;
            align-items: center;
            gap: 30px;
        }

        .profile-pic {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid var(--primary);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
            flex-shrink: 0;
        }

        .header-text {
            flex-grow: 1;
            padding-left: 20px;
            border-left: 4px solid var(--primary);
        }

        h1 {
            font-family: 'Poppins', sans-serif;
            font-size: 38px;
            text-transform: uppercase;
            letter-spacing: -1px;
            line-height: 1.1;
            margin-bottom: 5px;
            color: var(--text-dark);
        }

        .subtitle {
            font-size: 16px;
            color: var(--primary);
            font-weight: 600;
            font-family: 'Poppins', sans-serif;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .job-search-goal {
            font-size: 14px;
            color: var(--text-dark);
            font-weight: 500;
            margin-top: 4px;
        }

        .contact-info {
            margin-top: 15px;
            font-size: 12px;
            color: var(--text-light);
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .contact-item svg {
            flex-shrink: 0;
            color: var(--primary);
        }

        .content {
            display: grid;
            grid-template-columns: 65% 30%;
            justify-content: space-between;
            position: relative;
            z-index: 1;
            flex-grow: 1;
        }

        h2 {
            font-family: 'Poppins', sans-serif;
            font-size: 15px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-dark);
            border-bottom: 2px solid var(--bg-shape);
            padding-bottom: 8px;
            margin-bottom: 20px;
            margin-top: 5px;
        }

        .exp-item {
            margin-bottom: 25px;
        }

        .item-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 5px;
        }

        .role {
            font-weight: 700;
            font-size: 15px;
            color: var(--text-dark);
        }

        .company {
            font-family: 'Poppins', sans-serif;
            color: var(--primary);
            font-weight: 600;
            font-size: 13px;
        }

        .date {
            font-size: 12px;
            color: var(--text-light);
            font-feature-settings: "tnum";
            font-weight: 500;
        }

        .description {
            font-size: 13px;
            color: #475569;
            margin-bottom: 8px;
        }

        ul {
            list-style: none;
        }

        li {
            font-size: 13px;
            color: #475569;
            margin-bottom: 6px;
            padding-left: 15px;
            position: relative;
        }

        li::before {
            content: "•";
            color: var(--primary);
            position: absolute;
            left: 0;
            top: 0px;
            font-weight: bold;
            font-size: 16px;
            line-height: 1;
        }

        .skills-container {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .skill-tag {
            display: inline-block;
            border: 1px solid var(--primary);
            background: var(--bg-shape);
            color: var(--primary);
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .project-box {
            background: var(--bg-gray);
            padding: 12px 15px;
            border-radius: 10px;
            border-left: 3px solid var(--primary);
            margin-bottom: 15px;
        }

        .project-title {
            font-weight: 700;
            font-size: 13px;
            margin-bottom: 3px;
        }

        .project-stack {
            font-size: 10px;
            color: var(--text-light);
            margin-bottom: 6px;
            font-weight: 500;
            text-transform: uppercase;
        }

        .project-box .description {
            font-size: 12px;
            margin-bottom: 0;
            line-height: 1.5;
        }

        .edu-item {
            margin-bottom: 15px;
        }
    </style>
</head>

<body class="<%= theme === 'dark' ? 'dark-theme' : '' %>">
    <div class="page">
        <div class="shape-top-right"></div>
        <div class="shape-bottom-left"></div>
        <header>
            <% if (header.pictureBase64) { %>
                <img src="<%= header.pictureBase64 %>" class="profile-pic" />
                <% } %>
                    <div class="header-text">
                        <h1>
                            <%= header.name %>
                        </h1>
                        <div class="subtitle">
                            <%= header.title %>
                        </div>
                        <div class="job-search-goal">
                            <%= header.jobSearchGoal %>
                        </div>
                        <div class="contact-info">
                            <span class="contact-item">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M3 21a9 9 0 0 1 18 0"/></svg>
                                <%= header.age %>
                            </span>
                            <span class="contact-item">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                                <%= header.contact.location %>
                            </span>
                            <span class="contact-item">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                                <a href="mailto:<%= header.contact.email %>"><%= header.contact.email %></a>
                            </span>
                            <span class="contact-item">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
                                <a href="<%= header.contact.linkedinUrl %>" target="_blank"><%= header.contact.linkedinLabel %></a>
                            </span>
                            <span class="contact-item">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                                <a href="<%= header.contact.githubUrl %>" target="_blank"><%= header.contact.githubLabel %></a>
                            </span>
                            <span class="contact-item">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.06 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                <%= header.contact.phone %>
                            </span>
                        </div>
                    </div>
        </header>
        <div class="content">
            <div class="main-col">
                <h2><%= labels.experiences %></h2>
                <% experiences.forEach(function(exp) { %>
                    <div class="exp-item">
                        <div class="item-header"><span class="role">
                                <%= exp.role %>
                            </span><span class="date">
                                <%= exp.date %>
                            </span></div>
                        <div class="company">
                            <%= exp.company %>
                        </div>
                        <p class="description">
                            <%= exp.description %>
                        </p>
                        <ul>
                            <% exp.tasks.forEach(function(task) { %>
                                <li>
                                    <%= task %>
                                </li>
                                <% }); %>
                        </ul>
                    </div>
                    <% }); %>

                        <h2><%= labels.projects %></h2>
                        <% projects.forEach(function(p) { %>
                            <div class="project-box">
                                <div class="project-title">
                                    <%= p.title %>
                                </div>
                                <div class="project-stack">
                                    <%= p.stack %>
                                </div>
                                <p class="description">
                                    <%= p.description %>
                                </p>
                            </div>
                            <% }); %>
            </div>
            <div class="side-col">
                <h2><%= labels.education %></h2>
                <% education.forEach(function(edu) { %>
                    <div class="edu-item">
                        <div class="role">
                            <%= edu.degree %>
                        </div>
                        <div class="company">
                            <%= edu.school %>
                        </div>
                        <div class="date">
                            <%= edu.date %>
                        </div>
                        <p class="description" style="margin-top:5px;">
                            <%= edu.details %>
                        </p>
                    </div>
                    <% }); %>

                        <h2><%= labels.hardSkills %></h2>
                        <div class="skills-container">
                            <% skills.forEach(function(s) { %>
                                <span class="skill-tag">
                                    <%= s %>
                                </span>
                                <% }); %>
                        </div>

                        <h2 style="margin-top: 20px"><%= labels.softSkills %></h2>
                        <ul>
                            <% softSkills.forEach(function(s) { %>
                                <li>
                                    <%= s %>
                                </li>
                                <% }); %>
                        </ul>

                        <h2 style="margin-top: 25px"><%= labels.languages %></h2>
                        <% languages.forEach(function(l) { %>
                            <div class="edu-item">
                                <div class="item-header"><span class="role" style="font-size:14px">
                                        <%= l.name %>
                                    </span><span class="date" style="font-weight:600; color:var(--primary)">
                                        <%= l.level %>
                                    </span></div>
                            </div>
                            <% }); %>
            </div>
        </div>
    </div>
</body>

</html>