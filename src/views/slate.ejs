<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: <%= mainColor %>;
      --ink: #0f172a;
      --muted: #475569;
      --paper: #fffdf8;
      --panel: #f3efe5;
      --line: #d6d0c3;
      --accent: #111827;
    }

    body.dark-theme {
      --ink: #e5e7eb;
      --muted: #94a3b8;
      --paper: #0f172a;
      --panel: #111827;
      --line: #334155;
      --accent: #f8fafc;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Space Grotesk', sans-serif;
      color: var(--ink);
      background: var(--paper);
      font-size: 12px;
      line-height: 1.5;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .page {
      width: 210mm;
      min-height: 297mm;
      background: var(--paper);
      padding: 22px;
      position: relative;
      overflow: hidden;
    }

    .page::before {
      content: "";
      position: absolute;
      top: -120px;
      right: -80px;
      width: 260px;
      height: 260px;
      background: var(--panel);
      transform: rotate(16deg);
      border: 2px solid var(--line);
      z-index: 0;
    }

    .page::after {
      content: "";
      position: absolute;
      bottom: -90px;
      left: -70px;
      width: 220px;
      height: 220px;
      border: 28px solid var(--panel);
      border-radius: 50%;
      z-index: 0;
    }

    .content {
      position: relative;
      z-index: 1;
    }

    .masthead {
      border: 2px solid var(--line);
      background: linear-gradient(120deg, var(--panel) 0%, var(--paper) 70%);
      padding: 16px;
      margin-bottom: 14px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
    }

    .name {
      font-family: 'Source Serif 4', serif;
      font-size: 34px;
      line-height: 1;
      letter-spacing: -0.7px;
      text-transform: uppercase;
      margin-bottom: 2px;
      color: var(--accent);
    }

    .title {
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.6px;
      color: var(--primary);
      margin-bottom: 8px;
    }

    .goal {
      color: var(--muted);
      max-width: 94%;
      margin-bottom: 8px;
    }

    .contacts {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .contacts span,
    .contacts a {
      display: inline-flex;
      align-items: center;
      border: 1px solid var(--line);
      color: var(--ink);
      text-decoration: none;
      padding: 2px 7px;
      border-radius: 999px;
      font-size: 10px;
      background: var(--paper);
    }

    .photo {
      width: 92px;
      height: 92px;
      object-fit: cover;
      border-radius: 10px;
      border: 3px solid var(--primary);
      background: var(--panel);
    }

    .layout {
      display: grid;
      grid-template-columns: 65% 35%;
      gap: 12px;
    }

    .section {
      margin-bottom: 10px;
      border: 1px solid var(--line);
      background: var(--paper);
      padding: 10px;
    }

    h2 {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1.8px;
      font-weight: 700;
      color: var(--accent);
      margin-bottom: 8px;
      border-bottom: 1px solid var(--line);
      padding-bottom: 4px;
    }

    .entry {
      margin-bottom: 9px;
      padding-bottom: 9px;
      border-bottom: 1px dashed var(--line);
    }

    .entry:last-child {
      margin-bottom: 0;
      padding-bottom: 0;
      border-bottom: none;
    }

    .entry-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 8px;
      margin-bottom: 2px;
    }

    .entry-title {
      font-family: 'Source Serif 4', serif;
      font-size: 15px;
      font-weight: 600;
      color: var(--accent);
      line-height: 1.2;
    }

    .entry-date {
      font-size: 10px;
      white-space: nowrap;
      color: var(--muted);
      font-weight: 600;
    }

    .entry-subtitle {
      font-size: 11px;
      font-weight: 700;
      color: var(--primary);
      margin-bottom: 3px;
    }

    .entry-desc {
      color: var(--muted);
      margin-bottom: 3px;
    }

    ul {
      list-style: none;
    }

    li {
      position: relative;
      padding-left: 9px;
      margin-bottom: 2px;
      color: var(--muted);
    }

    li::before {
      content: "";
      position: absolute;
      top: 7px;
      left: 0;
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: var(--primary);
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
    }

    .chip {
      font-size: 10px;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 2px 7px;
      background: var(--panel);
      color: var(--ink);
    }

    .lang-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 4px;
      font-size: 11px;
    }

    .lang-row strong {
      color: var(--primary);
      font-weight: 700;
    }
  </style>
</head>

<body class="<%= theme === 'dark' ? 'dark-theme' : '' %>">
  <div class="page">
    <div class="content">
      <header class="masthead">
        <div>
          <h1 class="name"><%= header.name %></h1>
          <div class="title"><%= header.title %></div>
          <% if (header.jobSearchGoal) { %>
          <p class="goal"><%= header.jobSearchGoal %></p>
          <% } %>
          <div class="contacts">
            <% if (header.age) { %><span>Age: <%= header.age %></span><% } %>
            <% if (header.contact.location) { %><span><%= header.contact.location %></span><% } %>
            <% if (header.contact.phone) { %><span><%= header.contact.phone %></span><% } %>
            <% if (header.contact.email) { %><a href="mailto:<%= header.contact.email %>"><%= header.contact.email %></a><% } %>
            <% if (header.contact.linkedinLabel) { %><a href="<%= header.contact.linkedinUrl %>" target="_blank"><%= header.contact.linkedinLabel %></a><% } %>
            <% if (header.contact.githubLabel) { %><a href="<%= header.contact.githubUrl %>" target="_blank"><%= header.contact.githubLabel %></a><% } %>
          </div>
        </div>
        <% if (header.pictureBase64) { %>
        <img src="<%= header.pictureBase64 %>" class="photo" alt="Photo de profil" />
        <% } %>
      </header>

      <div class="layout">
        <main>
          <% if (experiences && experiences.length > 0) { %>
          <section class="section">
            <h2><%= labels.experiences %></h2>
            <% experiences.forEach(function(exp) { %>
            <article class="entry">
              <div class="entry-head">
                <div class="entry-title"><%= exp.role %></div>
                <div class="entry-date"><%= exp.date %></div>
              </div>
              <div class="entry-subtitle"><%= exp.company %></div>
              <% if (exp.description) { %><p class="entry-desc"><%= exp.description %></p><% } %>
              <% if (exp.tasks && exp.tasks.length > 0) { %>
              <ul>
                <% exp.tasks.forEach(function(task) { %><li><%= task %></li><% }); %>
              </ul>
              <% } %>
            </article>
            <% }); %>
          </section>
          <% } %>

          <% if (projects && projects.length > 0) { %>
          <section class="section">
            <h2><%= labels.projects %></h2>
            <% projects.forEach(function(project) { %>
            <article class="entry">
              <div class="entry-head">
                <div class="entry-title"><%= project.title %></div>
                <% if (project.stack) { %><div class="entry-date"><%= project.stack %></div><% } %>
              </div>
              <% if (project.description) { %><p class="entry-desc"><%= project.description %></p><% } %>
            </article>
            <% }); %>
          </section>
          <% } %>

          <% if (education && education.length > 0) { %>
          <section class="section">
            <h2><%= labels.education %></h2>
            <% education.forEach(function(edu) { %>
            <article class="entry">
              <div class="entry-head">
                <div class="entry-title"><%= edu.degree %></div>
                <div class="entry-date"><%= edu.date %></div>
              </div>
              <div class="entry-subtitle"><%= edu.school %></div>
              <% if (edu.details) { %><p class="entry-desc"><%= edu.details %></p><% } %>
            </article>
            <% }); %>
          </section>
          <% } %>
        </main>

        <aside>
          <% if (skills && skills.length > 0) { %>
          <section class="section">
            <h2><%= labels.hardSkills %></h2>
            <div class="chips">
              <% skills.forEach(function(skill) { %><span class="chip"><%= skill %></span><% }); %>
            </div>
          </section>
          <% } %>

          <% if (softSkills && softSkills.length > 0) { %>
          <section class="section">
            <h2><%= labels.softSkills %></h2>
            <ul>
              <% softSkills.forEach(function(skill) { %><li><%= skill %></li><% }); %>
            </ul>
          </section>
          <% } %>

          <% if (languages && languages.length > 0) { %>
          <section class="section">
            <h2><%= labels.languages %></h2>
            <% languages.forEach(function(lang) { %>
            <div class="lang-row"><span><%= lang.name %></span><strong><%= lang.level %></strong></div>
            <% }); %>
          </section>
          <% } %>
        </aside>
      </div>
    </div>
  </div>
</body>

</html>
