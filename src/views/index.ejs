<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV Generator Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <div class="container">
        <h1>CV Generator</h1>

        <form action="/generate-cv" method="GET" id="cvForm" target="_blank">
            <div class="form-group">
                <label for="domain">Domaine Cible</label>
                <input type="text" id="domain" name="domain" placeholder="ex: spotify.com" required>
            </div>

            <div class="form-group">
                <label for="color">Couleur de marque</label>
                <div style="display: flex; gap: 10px;">
                    <input type="color" id="colorPicker"
                        onchange="document.getElementById('color').value = this.value.substring(1)"
                        style="width: 50px; padding: 0;">
                    <input type="text" id="color" name="color" placeholder="ex: 005eb8">
                </div>
            </div>

            <div class="form-group">
                <label for="theme">Thème</label>
                <select id="theme" name="theme">
                    <option value="light">Clair (Standard)</option>
                    <option value="dark">Sombre (Dark Mode)</option>
                </select>
            </div>

            <button type="submit">Générer le PDF</button>
        </form>

        <div id="historySection" style="margin-top: 2rem; border-top: 1px solid #eee; padding-top: 1rem;">
            <h3>Derniers CVs générés</h3>
            <ul id="historyList" style="list-style: none; padding: 0;">
                <!-- Filled by JS -->
            </ul>
        </div>
    </div>
    <script src="/js/app.js"></script>
</body>

</html>