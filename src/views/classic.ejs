<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: <%=mainColor %>;
            --text-dark: #1f2937;
            --text-gray: #4b5563;
            --text-light: #9ca3af;
            --header-bg: #233142; /* Bleu très foncé pour l'en-tête */
            --header-text: #f9fafb;
            --header-accent: #60a5fa; /* Bleu clair pour le sous-titre */
            --bg-body: white;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--text-dark);
            background: #f0f2f5; /* Fond gris hors du CV pour bien voir la page */
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            font-size: 13px;
            line-height: 1.5;
        }

        /* Format A4 strict */
        .page {
            width: 210mm;
            min-height: 297mm;
            background: var(--bg-body);
            margin: 0 auto;
            position: relative;
            display: flex;
            flex-direction: column;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        a {
            color: var(--primary);
            text-decoration: none;
        }

        /* --- HEADER PLEINE LARGEUR --- */
        header {
            background-color: var(--header-bg);
            color: var(--header-text);
            padding: 35px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header-text {
            flex-grow: 1;
        }

        h1 {
            font-family: 'Poppins', sans-serif;
            font-size: 36px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 2px;
            line-height: 1.1;
        }

        .subtitle {
            font-family: 'Poppins', sans-serif;
            font-size: 16px;
            color: var(--header-accent);
            font-weight: 600;
            margin-bottom: 15px;
        }

        .contact-info {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            font-size: 11px;
            color: #d1d5db;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .contact-item a {
            color: #d1d5db;
        }

        .contact-item svg {
            color: var(--header-accent);
        }

        .profile-pic {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid #374151;
            flex-shrink: 0;
            margin-left: 20px;
        }

        /* --- CORPS DU CV --- */
        .content {
            display: grid;
            grid-template-columns: 60% 35%;
            gap: 5%;
            padding: 30px 40px;
            flex-grow: 1;
        }

        /* --- TITRES DE SECTION --- */
        h2 {
            font-family: 'Poppins', sans-serif;
            font-size: 16px;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--text-dark);
            border-bottom: 1px solid var(--text-dark);
            padding-bottom: 5px;
            margin-bottom: 15px;
            margin-top: 5px;
            letter-spacing: 0.5px;
        }

        /* Colonne de droite : Ajustement des marges pour les sous-sections */
        .side-col h2 {
            margin-top: 25px;
        }
        .side-col h2:first-child {
            margin-top: 5px;
        }

        h3.sub-section-title {
            font-size: 13px;
            font-weight: 700;
            margin-top: 15px;
            margin-bottom: 5px;
            color: var(--text-dark);
        }

        /* --- BLOCS D'EXPÉRIENCE / ÉDUCATION --- */
        .timeline-item {
            border-bottom: 1px dotted #cbd5e1;
            padding-bottom: 15px;
            margin-bottom: 15px;
        }

        .timeline-item:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .role {
            font-family: 'Poppins', sans-serif;
            font-size: 15px;
            font-weight: 600;
            color: var(--text-dark);
        }

        .company-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .company {
            color: var(--primary);
            font-weight: 500;
            font-size: 13px;
        }

        .date-location {
            font-size: 11px;
            color: var(--text-gray);
            font-weight: 500;
            display: flex;
            gap: 15px;
        }

        .date-location span {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .description {
            font-size: 12px;
            color: var(--text-gray);
            margin-bottom: 6px;
            line-height: 1.5;
        }

        /* --- LISTES ET PUCES --- */
        ul {
            list-style: none;
        }

        .task-list li {
            font-size: 12px;
            color: var(--text-gray);
            margin-bottom: 4px;
            padding-left: 12px;
            position: relative;
        }

        .task-list li::before {
            content: "•";
            color: var(--text-dark);
            position: absolute;
            left: 0;
            top: 0;
            font-weight: bold;
        }

        /* --- COLONNE DE DROITE (COMPÉTENCES, PROJETS, ETC.) --- */
        .about-text {
            font-size: 12px;
            color: var(--text-gray);
            line-height: 1.6;
            margin-bottom: 20px;
        }

        .skills-text {
            font-size: 12px;
            color: var(--text-gray);
            line-height: 1.6;
        }

        .project-item {
            margin-bottom: 12px;
        }
        
        .project-title {
            font-size: 12px;
            font-weight: 600;
            color: var(--primary);
        }
        
        .project-desc {
            font-size: 11px;
            color: var(--text-gray);
        }

        .language-item {
            font-size: 12px;
            margin-bottom: 6px;
        }
        
        .language-item strong {
            color: var(--text-dark);
        }
    </style>
</head>

<body>
    <div class="page">
        <header>
            <div class="header-text">
                <h1><%= header.name %></h1>
                <div class="subtitle"><%= header.title %></div>
                
                <div class="contact-info">
                    <% if (header.contact.phone) { %>
                    <span class="contact-item">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.06 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        <%= header.contact.phone %>
                    </span>
                    <% } %>

                    <% if (header.contact.email) { %>
                    <span class="contact-item">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                        <a href="mailto:<%= header.contact.email %>"><%= header.contact.email %></a>
                    </span>
                    <% } %>

                    <% if (header.contact.linkedinLabel) { %>
                    <span class="contact-item">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
                        <a href="<%= header.contact.linkedinUrl %>" target="_blank"><%= header.contact.linkedinLabel %></a>
                    </span>
                    <% } %>

                    <% if (header.contact.githubLabel) { %>
                    <span class="contact-item">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                        <a href="<%= header.contact.githubUrl %>" target="_blank"><%= header.contact.githubLabel %></a>
                    </span>
                    <% } %>

                    <% if (header.contact.location) { %>
                    <span class="contact-item">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                        <%= header.contact.location %>
                    </span>
                    <% } %>
                </div>
            </div>

            <% if (header.pictureBase64) { %>
                <img src="<%= header.pictureBase64 %>" class="profile-pic" alt="Photo de profil" />
            <% } %>
        </header>

        <div class="content">
            <div class="main-col">
                
                <% if (experiences && experiences.length > 0) { %>
                <h2><%= labels.experiences %></h2>
                <% experiences.forEach(function(exp) { %>
                    <div class="timeline-item">
                        <div class="role"><%= exp.role %></div>
                        <div class="company-row">
                            <div class="company"><%= exp.company %></div>
                            <div class="date-location">
                                <span><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg> <%= exp.date %></span>
                            </div>
                        </div>
                        <% if (exp.description) { %>
                            <p class="description"><%= exp.description %></p>
                        <% } %>
                        <% if (exp.tasks && exp.tasks.length > 0) { %>
                        <ul class="task-list">
                            <% exp.tasks.forEach(function(task) { %>
                                <li><%= task %></li>
                            <% }); %>
                        </ul>
                        <% } %>
                    </div>
                <% }); %>
                <% } %>

                <% if (education && education.length > 0) { %>
                <h2 style="margin-top: 30px;"><%= labels.education %></h2>
                <% education.forEach(function(edu) { %>
                    <div class="timeline-item">
                        <div class="role"><%= edu.degree %></div>
                        <div class="company-row">
                            <div class="company"><%= edu.school %></div>
                            <div class="date-location">
                                <span><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg> <%= edu.date %></span>
                            </div>
                        </div>
                        <% if (edu.details) { %>
                            <p class="description"><%= edu.details %></p>
                        <% } %>
                    </div>
                <% }); %>
                <% } %>
            </div>

            <div class="side-col">
                
                <% if (header.jobSearchGoal) { %>
                    <h2>À PROPOS</h2>
                    <p class="about-text"><%= header.jobSearchGoal %></p>
                <% } %>

                <% if ((skills && skills.length > 0) || (projects && projects.length > 0) || (softSkills && softSkills.length > 0)) { %>
                    <h2><%= labels.hardSkills || "COMPÉTENCES" %></h2>
                    
                    <% if (skills && skills.length > 0) { %>
                        <h3 class="sub-section-title">Outils & Technologies</h3>
                        <p class="skills-text">
                            <%= skills.join(', ') %>
                        </p>
                    <% } %>

                    <% if (projects && projects.length > 0) { %>
                        <h3 class="sub-section-title"><%= labels.projects || "Projets Notables" %></h3>
                        <% projects.forEach(function(p) { %>
                            <div class="project-item">
                                <div class="project-title"><%= p.title %></div>
                                <div class="project-desc"><%= p.description %> <% if(p.stack) { %>(<%= p.stack %>)<% } %></div>
                            </div>
                        <% }); %>
                    <% } %>

                    <% if (softSkills && softSkills.length > 0) { %>
                        <h3 class="sub-section-title"><%= labels.softSkills || "Soft Skills" %></h3>
                        <p class="skills-text">
                            <%= softSkills.join(', ') %>
                        </p>
                    <% } %>
                <% } %>

                <% if (languages && languages.length > 0) { %>
                    <h2>INFORMATIONS ADD.</h2>
                    
                    <h3 class="sub-section-title"><%= labels.languages || "Langues" %></h3>
                    <% languages.forEach(function(l) { %>
                        <div class="language-item">
                            <strong><%= l.name %> :</strong> <%= l.level %>
                        </div>
                    <% }); %>
                <% } %>

            </div>
        </div>
    </div>
</body>
</html>